{
    "env": "lunarlander",
    "network": {
        "hidden_dim": 128
    },

    "ppo": {
        "gamma": 0.99,
        "gae_lambda": 0.95,
        "clip_eps": 0.2,
        "entropy_coef": 0.01,
        "value_coef": 0.5
    },

    "training": {
        "actor_lr": 0.0001,
        "critic_lr": 0.0003,
        "epochs": 10,
        "batch_size": 128,
        "num_envs": 10
    },

    "logging": {
        "test_interval": 10,
        "test_trials": 10,
        "save_interval": 200
    }
}